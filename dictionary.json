{
  "meta": {
    "name": "Emoji News Script Ontology",
    "version": "0.2.0",
    "description": "An ontology mapping news concepts to emoji glyphs, with grammar markers, compounds, actions and modifiers for translating news articles into an emoji script.",
    "conventions": {
      "numbers": "Arabic numerals are passed through verbatim and prefixed with the quantity marker, e.g. 🔢250",
      "proper_names": "Unknown proper nouns are wrapped in the proper_name_wrapper and spelt out or replaced with a registered compound",
      "plurality": "Plural is marked with the plural marker after the concept glyph, e.g. 🏫🔁 = schools",
      "tense": "Tense markers precede the action glyph; absence of a marker implies present tense",
      "compound_order": "Compounds read left to right from the general to the specific, e.g. 🧩🏛️👔🏥🧩 = the health minister of the government"
    }
  },
  "grammar": {
    "compound_open": "🧩",
    "compound_close": "🧩",
    "proper_name_wrapper": "🏷️",
    "person_name_wrapper": "👤🏷️",
    "place_name_wrapper": "📍🏷️",
    "organisation_name_wrapper": "🏢🏷️",
