    "negation": "🚫",
    "plural": "🔁",
    "past_tense": "⏪",
    "future_tense": "⏩",
    "ongoing": "🔄",
    "beginning": "🎬",
    "ending": "🏁",
    "quote_open": "🗨️",
    "quote_close": "🗨️",
    "according_to": "🗣️➡️",
    "approximately": "〰️",
    "quantity_marker": "🔢",
    "comparison_more": "➕",
    "comparison_less": "➖",
